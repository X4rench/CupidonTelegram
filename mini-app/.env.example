# API URL — для локальной разработки указывает на backend на :3001
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Sentry DSN (опционально; для прода настоятельно рекомендуется)
VITE_SENTRY_DSN=

# Версия билда (для bug reports) — auto-выставляется CI/CD при деплое
VITE_BUILD_VERSION=dev

# ── ЮКасса (Phase I) ───────────────────────────────────────────────
# Включить кнопку "Купить картой" в Paywall (показывается рядом со Stars).
# Бэк должен иметь YK_SHOP_ID/YK_SECRET_KEY/YK_WEBHOOK_SECRET — иначе
# /payments/yookassa/invoice вернёт 503.
VITE_YOOKASSA_ENABLED=0

# Курс Stars → ₽ для отображения примерной цены рядом со звёздами
# (≈ 1.4-1.5 ₽/⭐). Меняется в @PremiumBot — обнови вручную при изменении.
VITE_STARS_TO_RUB=1.4

# Цены в рублях для UI (точные значения — на бэке в YK_PRICE_*).
# Если ЮКасса отключена — не используются.
VITE_RUB_PRICE_BASIC=299
VITE_RUB_PRICE_PREMIUM=899
VITE_RUB_PRICE_DAY_PASS=99

# Годовые / квартальные подписки.
VITE_RUB_PRICE_BASIC_3M=799
VITE_RUB_PRICE_BASIC_12M=2990
VITE_RUB_PRICE_PREMIUM_3M=2399
VITE_RUB_PRICE_PREMIUM_12M=8990
