# ═══════════════════════════════════════════════════════════════
# Cupidon TMA Backend — .env.example
# Копируй в .env и заполни. .env НЕ коммитится (см. .gitignore).
# ═══════════════════════════════════════════════════════════════

# ── LLM (polza.ai) ────────────────────────────────────────────────
POLZA_API_KEY=pza_xxxxxxxxxxxxxxxxxxxxxxxx
POLZA_API_URL=https://polza.ai/api/v1
POLZA_MODEL=qwen/qwen3-235b-a22b-2507

# ── HTTP-сервер ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# nginx hops: 0 = напрямую, 1 = за одним nginx
TRUST_PROXY_HOPS=0
# Где лежит SQLite. На проде — отдельная папка вне репо.
DB_PATH=./data/cupidon.sqlite

# ── Telegram Bot ──────────────────────────────────────────────────
# От @BotFather: /token
BOT_TOKEN=123456:AAH-XXXXXXX
BOT_USERNAME=CupidonAppBot
BOT_APP_NAME=app

# Webhook secret — генерируй: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=поменять_на_случайный_hex_32_символа

# Публичный URL backend для setWebhook (https://api.yourdomain.ru)
PUBLIC_BASE_URL=

# Канал для бонуса +5 запросов за подписку (H1 — реальная верификация через
# getChatMember). Формат: -100xxxxxxxxxx (id канала, не username). Бот должен
# быть админом канала, чтобы getChatMember работал.
# Пусто = fallback (DEV-режим: без верификации; в проде ОБЯЗАТЕЛЬНО заполнить).
TG_BONUS_CHANNEL_ID=

# ── Прокси к api.telegram.org (только для РФ-хоста) ───────────────
# Если бэкенд на AEZA Moscow или другом РФ-хосте — настрой Hetzner-прокси
# по DEPLOY-AEZA-RU.md §1. Для локалки/зарубежного хоста — оставь пустым.
TG_API_PROXY=

# ── DEV-режим ─────────────────────────────────────────────────────
# В DEV (NODE_ENV != production) можно отключить HMAC-валидацию initData
# чтобы тестировать с обычного браузера. В production ВСЕГДА=0.
DEV_BYPASS_INITDATA=1

# ── CORS ──────────────────────────────────────────────────────────
# Список разрешённых origin'ов через запятую (БЕЗ пробелов, БЕЗ trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173

# ── RBAC ──────────────────────────────────────────────────────────
# Telegram user_id админов через запятую (от @userinfobot)
ADMIN_TELEGRAM_IDS=794285476
# Старый ADMIN_SECRET оставляем как fallback для CLI/curl-сценариев
ADMIN_SECRET=поменять_на_длинный_случайный_секрет

# ── Rate limit ────────────────────────────────────────────────────
# Глобальный лимит — keying по tg_user_id (per-user, не per-IP).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
# Дополнительные жёсткие лимиты подключены отдельно в index.js:
#   /promo/apply               — 5 / час
#   /payments/*                — 10 / минуту
#   /users/claim-tg-bonus      — 3 / сутки

# ── initData TTL ──────────────────────────────────────────────────
# По стандарту TG — 24 часа. В проде НЕ повышать выше 86400 без причины
# (украденный initData = доступ к аккаунту, см. M7 в SECURITY_AUDIT).
INITDATA_TTL_SEC=86400

# ── Лимиты (бесплатный тариф) ─────────────────────────────────────
# Включить лимиты (для прода). 1 = включено, 0 = бесконечные запросы.
LIMITS_ENABLED=0
FREE_DAILY_LIMIT=3
BASIC_DAILY_LIMIT=30
PREMIUM_DAILY_LIMIT=100

# ── Цены тарифов в Stars ──────────────────────────────────────────
STAR_PRICE_BASIC=199
STAR_PRICE_PREMIUM=499
STAR_PRICE_DAY_PASS=50

# ── ЮКасса (Phase I — оплата картой) ──────────────────────────────
# Шоп и секретный ключ — из ЛК ЮКассы → Настройки → API.
YK_SHOP_ID=
YK_SECRET_KEY=
# Секрет для webhook от ЮКассы. Задаётся при создании webhook в ЛК:
# "Дополнительный заголовок" → имя X-YK-Webhook-Token, значение = этот секрет.
# Генерация: openssl rand -hex 32
YK_WEBHOOK_SECRET=
# Цены в рублях (целое число, без копеек). На UI отображаются как "≈ NNN ₽".
YK_PRICE_BASIC=299
YK_PRICE_PREMIUM=899
YK_PRICE_DAY_PASS=99

# Годовые/квартальные подписки (в рублях, целое). period передаётся в
# POST /payments/yookassa/invoice. Если переменная не задана — fallback к
# default из payments.js.
YK_PRICE_BASIC_3M=799
YK_PRICE_BASIC_12M=2990
YK_PRICE_PREMIUM_3M=2399
YK_PRICE_PREMIUM_12M=8990
# AES-256-GCM ключ для шифрования PII в payouts. openssl rand -base64 32
PAYOUT_ENCRYPTION_KEY=

# ── Business info ─────────────────────────────────────────────────
BUSINESS_INN=
BUSINESS_NAME=Cupidon

# ── Reconciliation ────────────────────────────────────────────────
RECONCILE_INTERVAL_MIN=5

# ── Партнёрская программа ─────────────────────────────────────────
# AI cost (₽, без копеек) — себестоимость одного запроса по тарифу.
# Используется при расчёте net = gross - ai_cost - yk_fee - tax.
AI_COST_BASIC=90
AI_COST_PREMIUM=300
AI_COST_DAY_PASS=20

# Налог самозанятого (НПД) при выплатах в РФ.
TAX_PCT=4

# Комиссия ЮКассы (% от валовых). Default 2.8.
# Также поддерживается RUB_COMMISSION_PCT_BUFFER (legacy alias) — если задана,
# используется она.
YK_FEE_PCT=2.8

# Hold в днях между регистрацией commission (pending) и тем как она становится
# available (готовой к выплате). За это время refund удалит commission.
PARTNER_HOLD_DAYS=14

# Минимум для выплаты партнёру (в рублях). Меньше — копится дальше.
PARTNER_MIN_PAYOUT_RUB=2000
